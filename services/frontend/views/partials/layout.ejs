<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title><%= typeof title !== 'undefined' ? title : 'Bike Club' %></title>
      <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" 
          rel="stylesheet" 
          crossorigin="anonymous">
    <link rel="stylesheet" href="/css/style.css">
        <meta charset="UTF-8">
    <link href="https://fonts.googleapis.com/css?family=Roboto:300,400&display=swap" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css?family=Poppins:300,400,500&display=swap" rel="stylesheet">

    <link href="https://fonts.googleapis.com/css?family=Source+Serif+Pro:400,600&display=swap" rel="stylesheet">
      <link href="https://fonts.googleapis.com/css?family=Source+Serif+Pro:400,600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="fonts/icomoon/style.css">
    <style>
        body { background: #f8f9fa; }

        /* Card hover lift */
        .card-hover { transition: transform 0.2s, box-shadow 0.2s; }
        .card-hover:hover { transform: translateY(-4px); box-shadow: 0 8px 25px rgba(0,0,0,0.12); }

        /* Status badges */
        .badge { font-size: 0.75rem; padding: 0.4em 0.8em; border-radius: 20px; }

        /* Page header */
     .page-header {
    background: linear-gradient(135deg, #1a1a2e, #16213e);
    color: white;
    padding: 5rem 0;        /* ← increase padding */
    margin-bottom: 2rem;
    min-height: 300px;      /* ← add this */
    display: flex;
    align-items: center;
    justify-content: center;
}

        /* Active nav link */
        .navbar .nav-link:hover { color: #4fc3f7 !important; }

        /* Voucher code font */
        .font-monospace { letter-spacing: 0.1em; }
    </style>
</head>
<body>
    <%- include('nav') %>
    <main><%- body %></main>
     <%- include('partials/footer') %>
     <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
            crossorigin="anonymous"></script>
</body>
</html>
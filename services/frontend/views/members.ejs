<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Members — Bike Club</title>
    <meta name="viewport" content="width=device-width, initial-scale=1">
     <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Source+Serif+Pro:400,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="fonts/icomoon/style.css">
    <style>
       
        .page-header {
            background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
            color: white;
            padding: 2rem 0 3rem;
            margin-bottom: -2rem;
        }
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
        .member-card { transition: transform 0.2s, box-shadow 0.2s; cursor: pointer; }
        .member-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(0,0,0,0.12); }
        .avatar-circle {
            width: 56px; height: 56px; border-radius: 50%;
            background: linear-gradient(135deg, #1a1a2e, #4fc3f7);
            display: flex; align-items: center; justify-content: center;
            font-size: 1.4rem; flex-shrink: 0;
        }
        .bike-badge {
            font-size: 0.7rem; padding: 0.3em 0.7em;
            border-radius: 20px; background: #e3f2fd; color: #1565c0;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partials/nav') %>

    <!-- Page header -->
    <div class="page-header">
        <div class="container">
            <h3 class="fw-bold mb-0">👥 Club Members</h3>
            <p class="mb-0 mt-1" style="color: rgba(255,255,255,0.6);">
                <%= members.length %> member<%= members.length !== 1 ? 's' : '' %> in the club
            </p>
        </div>
    </div>

    <main class="flex-grow-1">
        <div class="container py-4" style="max-width: 900px;">

            <!-- Alerts -->
            <% if (typeof success !== 'undefined' && success) { %>
            <div class="alert alert-success alert-dismissible fade show">
                ✓ <%= success %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>
            <% if (typeof error !== 'undefined' && error) { %>
            <div class="alert alert-danger alert-dismissible fade show">
                ✗ <%= error %>
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            <% } %>

            <% if (members.length === 0) { %>
                <div class="text-center text-muted py-5">
                    <div class="fs-1 mb-2">👥</div>
                    <p>No members found</p>
                </div>
            <% } else { %>
            <div class="row g-3">
                <% members.forEach(member => { %>
                <div class="col-md-6">
                    <div class="card member-card">
                        <div class="card-body p-3">
                            <div class="d-flex align-items-center gap-3">

                                <!-- Avatar -->
                                <% if (member.avatar) { %>
                                    <img src="<%= member.avatar %>"
                                         width="56" height="56"
                                         class="rounded-circle"
                                         style="object-fit:cover; flex-shrink:0;">
                                <% } else { %>
                                    <div class="avatar-circle">🚴</div>
                                <% } %>

                                <!-- Info -->
                                <div class="flex-grow-1 min-width-0">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="fw-bold mb-0">
                                                <%= member.name || 'Cyclist' %>
                                            </h6>
                                            <div class="text-muted small">
                                                📍 <%= member.city || 'Location not set' %>
                                            </div>
                                        </div>
                                        <span class="badge rounded-pill bg-<%= member.membershipStatus === 'active' ? 'success' : member.membershipStatus === 'suspended' ? 'warning' : 'danger' %>">
                                            <%= member.membershipStatus %>
                                        </span>
                                    </div>

                                    <div class="mt-2 d-flex align-items-center gap-2 flex-wrap">
                                        <span class="bike-badge">
                                            🚲 <%= member.bikeType || 'other' %>
                                        </span>
                                        <span class="text-muted small">
                                            📅 Joined <%= new Date(member.joinedAt).toLocaleDateString() %>
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Bio preview if exists -->
                            <% if (member.bio && member.bio.trim()) { %>
                            <p class="text-muted small fst-italic mt-2 mb-0 border-top pt-2">
                                "<%= member.bio.trim().substring(0, 80) %><%= member.bio.trim().length > 80 ? '...' : '' %>"
                            </p>
                            <% } %>

                            <!-- Admin actions if admin -->
                            <% if (typeof isAdmin !== 'undefined' && isAdmin) { %>
                            <div class="mt-2 border-top pt-2 d-flex gap-2">
                                <% if (member.membershipStatus === 'active') { %>
                                <form method="POST"
                                      action="/admin/members/<%= member._id %>/suspend?token=<%= token %>"
                                      style="display:inline">
                                    <button class="btn btn-sm btn-warning">Suspend</button>
                                </form>
                                <% } else { %>
                                <form method="POST"
                                      action="/admin/members/<%= member._id %>/activate?token=<%= token %>"
                                      style="display:inline">
                                    <button class="btn btn-sm btn-success">Activate</button>
                                </form>
                                <% } %>
                            </div>
                            <% } %>

                        </div>
                    </div>
                </div>
                <% }) %>
            </div>
            <% } %>

        </div>
    </main>

    <%- include('partials/footer') %>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Profile — Bike Club</title>
     <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css?family=Source+Serif+Pro:400,600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="fonts/icomoon/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partials/nav') %>
    <main class="flex-grow-1">
    <div class="container mt-4">
        <div class="row justify-content-center">
            <div class="col-md-7">

                <!-- Alerts -->
                <% if (success) { %>
                <div class="alert alert-success"><%= success %></div>
                <% } %>
                <% if (error) { %>
                <div class="alert alert-danger"><%= error %></div>
                <% } %>

                <div class="card shadow">
                    <div class="card-body p-4">

                        <!-- Header -->
                        <div class="text-center mb-4">
                            <% if (member.avatar) { %>
                                <img src="<%= member.avatar %>"
                                     class="rounded-circle mb-2"
                                     width="100" height="100"
                                     style="object-fit:cover; border: 3px solid #0d6efd;">
                            <% } else { %>
                                <div class="display-1">🚴</div>
                            <% } %>
                            <h4 class="mb-0"><%= member.name || member.email || 'Cyclist' %></h4>
                            <div class="text-muted small mb-2"><%= member.email || '' %></div>
                            <span class="badge bg-<%= member.membershipStatus === 'active' ? 'success' : 'warning' %>">
                                <%= member.membershipStatus %>
                            </span>
                        </div>

                        <!-- Read-only details -->
                        <ul class="list-group list-group-flush mb-4">
                            <li class="list-group-item d-flex justify-content-between">
                                <span class="text-muted">📍 City</span>
                                <strong><%= member.city || '—' %></strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between">
                                <span class="text-muted">📞 Phone</span>
                                <strong><%= member.phone || '—' %></strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between">
                                <span class="text-muted">🚲 Bike Type</span>
                                <strong><%= member.bikeType || '—' %></strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between">
                                <span class="text-muted">📅 Joined</span>
                                <strong><%= new Date(member.joinedAt).toDateString() %></strong>
                            </li>
                            <li class="list-group-item d-flex justify-content-between">
                                <span class="text-muted">🔄 Last Updated</span>
                                <strong><%= new Date(member.updatedAt).toDateString() %></strong>
                            </li>
                        </ul>

                        <!-- Full bio -->
                        <div class="mb-4">
                            <h6 class="text-muted">About</h6>
                            <p class="mb-0">
                                <%= member.bio && member.bio.trim() ? member.bio.trim() : 'No bio added yet.' %>
                            </p>
                        </div>

                        <!-- Edit form -->
                        <hr>
                        <h6 class="mb-3">Edit Profile</h6>

                        <form method="POST" action="/profile" id="profileForm">
    <!-- Avatar Upload -->
    <div class="mb-4 text-center">
        <div id="avatarPreview" class="mb-2">
            <% if (member.avatar) { %>
                <img id="previewImg" src="<%= member.avatar %>"
                     class="rounded-circle"
                     width="100" height="100"
                     style="object-fit:cover; border: 3px solid #0d6efd;">
            <% } else { %>
                <div id="previewImg" class="display-1">🚴</div>
            <% } %>
        </div>
        <label for="avatarInput" class="btn btn-sm btn-outline-secondary">
            📷 Change Photo
        </label>
        <input type="file" id="avatarInput" accept="image/*"
               class="d-none" onchange="previewAvatar(event)">
        <input type="hidden" name="avatar" id="avatarBase64"
               value="<%= member.avatar || '' %>">
        <div class="text-muted small mt-1">JPG, PNG, GIF, WEBP — any format</div>
    </div>

                            <div class="mb-3">
                                <label class="form-label">Name</label>
                                <input type="text" name="name" class="form-control"
                                       value="<%= member.name || '' %>">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Phone</label>
                                <input type="text" name="phone" class="form-control"
                                       value="<%= member.phone || '' %>">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">City</label>
                                <input type="text" name="city" class="form-control"
                                       value="<%= member.city || '' %>">
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Bike Type</label>
                                <select name="bikeType" class="form-select">
                                    <% ['road', 'mountain', 'hybrid', 'bmx', 'other'].forEach(type => { %>
                                    <option value="<%= type %>"
                                        <%= member.bikeType === type ? 'selected' : '' %>>
                                        <%= type.charAt(0).toUpperCase() + type.slice(1) %>
                                    </option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="mb-3">
                                <label class="form-label">Bio</label>
                                <textarea name="bio" class="form-control" rows="3"><%= member.bio ? member.bio.trim() : '' %></textarea>
                            </div>
                            <button type="submit" class="btn btn-primary w-100">
                                Save Changes
                            </button>
                        </form>

                    </div>
                </div>

                <a href="/dashboard" class="btn btn-outline-secondary w-100 mt-3">
                    ← Back to Dashboard
                </a>

            </div>
        </div>
    </div>
</main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<%- include('partials/footer') %>
<!-- Edit form -->
<hr>
<h6 class="mb-3">Edit Profile</h6>

<form method="POST" action="/profile" id="profileForm">
    <!-- Avatar Upload -->
    <div class="mb-4 text-center">
        <div id="avatarPreview" class="mb-2">
            <% if (member.avatar) { %>
                <img id="previewImg" src="<%= member.avatar %>"
                     class="rounded-circle"
                     width="100" height="100"
                     style="object-fit:cover; border: 3px solid #0d6efd;">
            <% } else { %>
                <div id="previewImg" class="display-1">🚴</div>
            <% } %>
        </div>
        <label for="avatarInput" class="btn btn-sm btn-outline-secondary">

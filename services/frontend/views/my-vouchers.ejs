<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Vouchers — Bike Club</title>
     <link rel="stylesheet" href="/css/style.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
      <link href="https://fonts.googleapis.com/css?family=Source+Serif+Pro:400,600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="fonts/icomoon/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partials/nav') %>
    <main class="flex-grow-1">
    <div class="container mt-4" style="max-width: 800px; margin: 0 auto;">
        <div class="d-flex justify-content-between mb-4">
            <h4>🎟️ My Vouchers</h4>
            <a href="/dashboard" class="btn btn-outline-secondary btn-sm">← Dashboard</a>
        </div>
        <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success alert-dismissible fade show">
            ✓ <%= success %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger alert-dismissible fade show">
            ✗ <%= error %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
        <% } %>
        <% if (vouchers.length === 0) { %>
            <div class="alert alert-info">You have no vouchers yet. Join an event to get one!</div>
        <% } else { %>
        <div class="row g-3">
            <% vouchers.forEach(voucher => { %>
            <div class="col-md-6">
                <div class="card h-100 border-<%=
                    voucher.status === 'active'  ? 'success'   :
                    voucher.status === 'used'    ? 'secondary' :
                    voucher.status === 'expired' ? 'warning'   : 'danger'
                %>">
                    <div class="card-body">
                         <h6 class="mb-3"><%= voucher.eventTitle || 'Event Voucher' %></h6>
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div>
                                <div class="text-muted small mb-1">Voucher Code</div>
                                <h5 class="font-monospace mb-0"><%= voucher.code %></h5>
                            </div>
                            <span class="badge bg-<%=
                                voucher.status === 'active'  ? 'success'   :
                                voucher.status === 'used'    ? 'secondary' :
                                voucher.status === 'expired' ? 'warning'   : 'danger'
                            %>"><%= voucher.status %></span>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Amount</span>
                            <strong><%= voucher.currency %> <%= voucher.amount %></strong>
                        </div>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Expires</span>
                            <strong><% if (voucher.expiresAt) { %><%= new Date(voucher.expiresAt).toDateString() %><% } else { %>—<% } %></strong>
                        </div>
                        <% if (voucher.usedAt) { %>
                        <div class="d-flex justify-content-between mb-2">
                            <span class="text-muted small">Used On</span>
                            <strong><%= new Date(voucher.usedAt).toDateString() %></strong>
                        </div>
                        <% } %>
                        <div class="d-flex justify-content-between">
                            <span class="text-muted small">Issued</span>
                            <strong><%= new Date(voucher.createdAt).toDateString() %></strong>
                        </div>
                    </div>
                    <% if (voucher.status === 'active') { %>
                    <div class="card-footer bg-transparent border-success">
                        <small class="text-success">✓ Valid and ready to use</small>
                    </div>
                    <% } else if (voucher.status === 'used') { %>
                    <div class="card-footer bg-transparent">
                        <small class="text-muted">✓ Redeemed</small>
                    </div>
                    <% } else if (voucher.status === 'expired') { %>
                    <div class="card-footer bg-transparent border-warning">
                        <small class="text-warning">⚠ Expired</small>
                    </div>
                    <% } else if (voucher.status === 'revoked') { %>
                    <div class="card-footer bg-transparent border-danger">
                        <small class="text-danger">✗ Revoked</small>
                    </div>
                    <% } %>
                </div>
            </div>
            <% }) %>
        </div>
        <% } %>
    </div>
    </main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<%- include('partials/footer') %>

</body>
</html>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Payment — Bike Club</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <%- include('partials/nav') %>
    <main class="flex-grow-1">

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow text-center p-5">

                <div class="display-1 mb-3">📱</div>
                <h3>Check Your Phone</h3>
                <p class="text-muted">
                    An MPesa prompt has been sent to your Safaricom number.
                    Enter your PIN to complete the payment.
                </p>

                <div class="alert alert-info mt-3">
                    <div class="spinner-border spinner-border-sm me-2 text-primary"></div>
                    Waiting for payment confirmation...
                </div>

                <!-- Countdown -->
                <div class="text-muted small mt-2">
                    Time remaining: <span id="countdown" class="fw-bold">60s</span>
                </div>

                <div id="result" class="mt-3"></div>

                <a href="/" class="btn btn-outline-secondary btn-sm mt-4">
                    Cancel — Go Home
                </a>
            </div>
        </div>
    </div>
</div>
</main>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<%- include('partials/footer') %>



<script>
    const checkoutId = '<%= checkoutId %>';
    const eventId = '<%= eventId %>';
    const INTERVAL = 2000;
    let attempts = 0;
    const MAX = 60; // 30 polls × 2 seconds = 60 seconds

    // Countdown timer
    let timeLeft = 120;
    const countdownEl = document.getElementById('countdown');
    const countdownTimer = setInterval(() => {
        timeLeft--;
        countdownEl.textContent = `${timeLeft}s`;
        if (timeLeft <= 0) clearInterval(countdownTimer);
    }, 1000);



    // Poll for payment status
    const poll = setInterval(async () => {
        attempts++;

        if (attempts > MAX) {
            clearInterval(poll);
            clearInterval(countdownTimer);
            document.getElementById('result').innerHTML = `
                <div class="alert alert-warning">
                    <strong>Timed out.</strong> If you completed the payment
                    your voucher will appear in your
                    <a href="/dashboard">dashboard</a> shortly.
                    <br><br>
                    <a href="/events/${eventId}/pay" class="btn btn-sm btn-primary">
                        Try Again
                    </a>
                </div>`;
            return;
        }

        try {
            const res = await fetch(`/payment/status/${checkoutId}`);
            const data = await res.json();

            if (data.status === 'completed') {
                clearInterval(poll);
                clearInterval(countdownTimer);
                document.getElementById('result').innerHTML = `
                    <div class="alert alert-success">
                        ✅ Payment successful!
                    </div>`;
                setTimeout(() => {
                    window.location.href = '/dashboard?success=Payment successful! Your voucher is ready.';
                }, 1500);
            }

            if (data.status === 'failed') {
                clearInterval(poll);
                clearInterval(countdownTimer);
                document.getElementById('result').innerHTML = `
                    <div class="alert alert-danger">
                        ❌ Payment failed.
                         <div class="mt-2">
                        <a href="/events/${eventId}/pay" class="btn btn-sm btn-primary me-2">
                    Try Again
                </a>
                <a href="/dashboard" class="btn btn-sm btn-outline-secondary">
                    Go to Dashboard
                </a>
                 </div>
                    </div>`;
            }

        } catch (err) {
            console.error('Poll error:', err);
        }

    }, INTERVAL);
</script>
<script src="https://js.stripe.com/v3/"></script>
</body>
</html>
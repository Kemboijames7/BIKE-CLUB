<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Members — Bike Club Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container-fluid p-4">
    <div class="d-flex justify-content-between mb-4">
        <h3>👥 Members</h3>
        <a href="/admin/dashboard?token=<%= token %>" class="btn btn-outline-secondary">
            ← Dashboard
        </a>
    </div>
    <div class="card">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>ID</th>
                        <th>City</th>
                        <th>Bike Type</th>
                        <th>Status</th>
                        <th>Joined</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% members.forEach(member => { %>
                    <tr>
                        <td><small><%= member.userId %></small></td>
                        <td><%= member.city || 'N/A' %></td>
                        <td><%= member.bikeType %></td>
                        <td>
                            <span class="badge bg-<%= member.membershipStatus === 'active' ? 'success' : 'danger' %>">
                                <%= member.membershipStatus %>
                            </span>
                        </td>
                        <td><%= new Date(member.joinedAt).toDateString() %></td>
                        <td>
                            <% if (member.membershipStatus === 'active') { %>
                            <form method="POST" action="/admin/members/<%= member._id %>/suspend?token=<%= token %>" style="display:inline">
                                <button class="btn btn-sm btn-warning">Suspend</button>
                            </form>
                            <% } else { %>
                            <form method="POST" action="/admin/members/<%= member._id %>/activate?token=<%= token %>" style="display:inline">
                                <button class="btn btn-sm btn-success">Activate</button>
                            </form>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>
</div>
</body>
</html>
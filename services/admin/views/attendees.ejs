<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Attendees — <%= event.title %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #f5f5f0; }
        .page-header {
            background: linear-gradient(135deg, #1b4332 0%, #2563eb 100%);
            color: white;
            padding: 2.5rem 0;
            margin-bottom: 2rem;
        }
        .stat-card {
            background: white;
            border-radius: 12px;
            padding: 1.25rem 1.5rem;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            margin-bottom: 1.5rem;
        }
        .stat-card .number {
            font-size: 2rem;
            font-weight: 700;
            color: #1b4332;
        }
        .stat-card .label {
            font-size: 0.8rem;
            color: #6c757d;
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }
        .table-card {
            background: white;
            border-radius: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            overflow: hidden;
        }
        .badge-mpesa  { background: #e8f5e9; color: #1b4332; }
        .badge-stripe { background: #e8f0fe; color: #2563eb; }
        .badge-completed { background: #e8f5e9; color: #1b4332; }
        .badge-pending   { background: #fef3c7; color: #92400e; }
        .badge-failed    { background: #fde8e8; color: #c0392b; }
    </style>
</head>
<body>
    <div class="page-header">
        <div class="container">
            <a href="/admin/events" class="text-white text-decoration-none small">← Back to Events</a>
            <h1 class="mt-2 mb-1"><%= event.title %></h1>
            <p class="mb-0 opacity-75">
                📍 <%= event.location %> &nbsp;|&nbsp;
                📅 <%= new Date(event.date).toLocaleDateString('en-KE', { dateStyle: 'long' }) %> &nbsp;|&nbsp;
                🎟️ <%= event.registered || 0 %> / <%= event.capacity %> registered
            </p>
        </div>
    </div>

    <div class="container">

        <!-- Stats -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="number"><%= total %></div>
                    <div class="label">Confirmed Attendees</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="number">KES <%= revenue.toLocaleString() %></div>
                    <div class="label">Total Revenue</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="stat-card">
                    <div class="number"><%= event.capacity - total %></div>
                    <div class="label">Spots Remaining</div>
                </div>
            </div>
        </div>

        <!-- Attendees Table -->
        <div class="table-card">
            <div class="p-3 border-bottom d-flex justify-content-between align-items-center">
                <strong>Attendees</strong>
                <input type="text" id="searchBox" class="form-control form-control-sm w-auto"
                       placeholder="Search...">
            </div>

            <% if (attendees.length === 0) { %>
            <div class="text-center text-muted py-5">
                <div class="fs-1">🚲</div>
                <p>No confirmed attendees yet.</p>
            </div>
            <% } else { %>
            <div class="table-responsive">
                <table class="table table-hover mb-0" id="attendeesTable">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Member ID</th>
                            <th>Amount</th>
                            <th>Method</th>
                            <th>Status</th>
                            <th>Receipt</th>
                            <th>Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% attendees.forEach((p, i) => { %>
                        <tr>
                            <td class="text-muted"><%= i + 1 %></td>
                            <td><code><%= p.memberId %></code></td>
                            <td><strong>KES <%= p.amount.toLocaleString() %></strong></td>
                            <td>
                                <span class="badge badge-<%= p.method %>">
                                    <%= p.method === 'mpesa' ? '📱 M-Pesa' : '💳 Stripe' %>
                                </span>
                            </td>
                            <td>
                                <span class="badge badge-<%= p.status %>"><%= p.status %></span>
                            </td>
                            <td>
                                <small class="text-muted">
                                    <%= p.mpesaReceiptNumber || p.stripePaymentId || '—' %>
                                </small>
                            </td>
                            <td>
                                <small><%= new Date(p.createdAt).toLocaleDateString() %></small>
                            </td>
                        </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
            <% } %>
        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const searchBox = document.getElementById('searchBox');
        if (searchBox) {
            searchBox.addEventListener('input', () => {
                const q = searchBox.value.toLowerCase();
                document.querySelectorAll('#attendeesTable tbody tr').forEach(row => {
                    row.style.display = row.textContent.toLowerCase().includes(q) ? '' : 'none';
                });
            });
        }
    </script>
</body>
</html>
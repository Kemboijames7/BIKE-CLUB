<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Newsletter — Bike Club Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
<div class="container-fluid p-4">
    <div class="d-flex justify-content-between mb-4">
        <h3>📧 Newsletter</h3>
        <a href="/admin/dashboard?token=<%= token %>" class="btn btn-outline-secondary">
            ← Dashboard
        </a>
    </div>

    <!-- Stats -->
    <div class="row g-3 mb-4">
        <div class="col-md-4">
            <div class="card p-3 border-success">
                <div class="text-muted small">Subscribed</div>
                <div class="fs-3 fw-bold text-success"><%= stats.subscribed %></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 border-danger">
                <div class="text-muted small">Unsubscribed</div>
                <div class="fs-3 fw-bold text-danger"><%= stats.unsubscribed %></div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card p-3 border-primary">
                <div class="text-muted small">Total</div>
                <div class="fs-3 fw-bold text-primary"><%= stats.total %></div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Send campaign -->
        <div class="col-md-7">
            <div class="card">
                <div class="card-header"><strong>Send Campaign</strong></div>
                <div class="card-body">
                    <form id="campaignForm">
                        <div class="mb-3">
                            <label class="form-label">Subject</label>
                            <input type="text" id="subject" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Content (HTML supported)</label>
                            <textarea id="content" class="form-control" rows="8"
                                      placeholder="<h2>Hello Cyclists!</h2><p>Your content here...</p>"
                                      required></textarea>
                        </div>
                        <button type="submit" class="btn btn-primary">
                            📨 Send to <%= stats.subscribed %> Subscribers
                        </button>
                    </form>
                    <div id="campaignResult" class="mt-3"></div>
                </div>
            </div>
        </div>

        <!-- Subscribers list -->
        <div class="col-md-5">
            <div class="card">
                <div class="card-header">
                    <strong>Subscribers (<%= stats.subscribed %>)</strong>
                </div>
                <div class="card-body p-0" style="max-height:500px;overflow-y:auto">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Email</th>
                                <th>Joined</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% subscribers.forEach(sub => { %>
                            <tr>
                                <td>
                                    <div><%= sub.email %></div>
                                    <small class="text-muted"><%= sub.name || '—' %></small>
                                </td>
                                <td>
                                    <small><%= new Date(sub.subscribedAt).toDateString() %></small>
                                </td>
                            </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.getElementById('campaignForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const subject = document.getElementById('subject').value;
    const content = document.getElementById('content').value;
    const result = document.getElementById('campaignResult');
    const btn = e.target.querySelector('button');

    btn.disabled = true;
    btn.textContent = 'Sending...';

    try {
        const res = await fetch('/admin/newsletter/send?token=<%= token %>', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ subject, content })
        });

        const data = await res.json();

        result.innerHTML = res.ok
            ? `<div class="alert alert-success">✅ ${data.message}</div>`
            : `<div class="alert alert-danger">❌ ${data.error}</div>`;

    } catch (err) {
        result.innerHTML = '<div class="alert alert-danger">❌ Network error</div>';
    } finally {
        btn.disabled = false;
        btn.textContent = '📨 Send to <%= stats.subscribed %> Subscribers';
    }
});
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
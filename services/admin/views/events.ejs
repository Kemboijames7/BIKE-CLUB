<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Events — Bike Club Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    /* Prevent status and actions from wrapping */
    table th:nth-child(7),
    table td:nth-child(7),
    table th:nth-child(8),
    table td:nth-child(8) {
        white-space: nowrap;
        width: 1%;  /* shrink to content */
    }

    /* Let title and description columns absorb the squeeze */
    table th:nth-child(1),
    table td:nth-child(1) {
        min-width: 150px;
        max-width: 200px;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
    }

    /* Make table scroll horizontally on small screens instead of breaking */
    .table-responsive {
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }
</style>
</head>
<body>
<div class="container-fluid p-4">
    <div class="d-flex justify-content-between mb-4">
        <h3>🗓️ Events</h3>
        <div>
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createModal">
                + Create Event
            </button>
            <a href="/admin/dashboard?token=<%= token %>" class="btn btn-outline-secondary ms-2">
                ← Dashboard
            </a>
        </div>
    </div>

    <div class="card">
        <div class="card-body p-0">
            <div class="card">
    <div class="card-body p-0">
        <div class="table-responsive"> 
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Title</th>
                        <th>Type</th>
                        <th>Location</th>
                        <th>Date</th>
                        <th>Capacity</th>
                        <th>Price</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% events.forEach(event => { %>
                    <tr>
                        <td><strong><%= event.title %></strong></td>
                        <td><span class="badge bg-secondary"><%= event.type %></span></td>
                        <td><%= event.location %></td>
                        <td><%= new Date(event.date).toDateString() %></td>
                        <td><%= event.registered %>/<%= event.capacity %></td>
                        <td>KES <%= event.price %></td>
                        <td>
                            <span class="badge bg-<%= event.status === 'upcoming' ? 'primary' : 'secondary' %>">
                                <%= event.status %>
                            </span>
                        </td>
                        <td>
                           
                            <% if (event.status !== 'cancelled') { %>
                            <form method="POST" action="/admin/events/<%= event._id %>/cancel?token=<%= token %>" style="display:inline">
                                <button class="btn btn-sm btn-danger"
                                    onclick="return confirm('Cancel this event?')">
                                    Cancel
                                </button>
                            </form>
                            <% } %>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
            </div>                           
    </div>
</div>
        </div>
    </div>
</div>

<!-- Create Event Modal -->
<div class="modal fade" id="createModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Create New Event</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form method="POST" action="/admin/events?token=<%= token %>">
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Title</label>
                        <input type="text" name="title" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Description</label>
                        <textarea name="description" class="form-control" rows="3" required></textarea>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label">Type</label>
                            <select name="type" class="form-select" required>
                                <option value="ride">Ride</option>
                                <option value="campaign">Campaign</option>
                                <option value="webinar">Webinar</option>
                                <option value="race">Race</option>
                                <option value="social">Social</option>
                            </select>
                        </div>
                        <div class="col mb-3">
                            <label class="form-label">Capacity</label>
                            <input type="number" name="capacity" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Location</label>
                        <input type="text" name="location" class="form-control" required>
                    </div>
                    <div class="row">
                        <div class="col mb-3">
                            <label class="form-label">Date</label>
                            <input type="datetime-local" name="date" class="form-control" required>
                        </div>
                        <div class="col mb-3">
                            <label class="form-label">Price (KES)</label>
                            <input type="number" name="price" class="form-control" value="0">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="hasLiveChat" value="true">
                                <label class="form-check-label">Live Chat</label>
                            </div>
                        </div>
                        <div class="col">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="hasCommentary" value="true">
                                <label class="form-check-label">Commentary</label>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Create Event</button>
                </div>
            </form>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>